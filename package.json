{
  "name": "helpdesk-monorepo",
  "version": "1.0.0",
  "scripts": {
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && py -m uvicorn main:app --reload --port 8001",
    "dev": "npm-run-all --parallel dev:frontend dev:backend"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "dependencies": {
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7"
  }
}
